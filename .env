# Copy to .env and adjust. Used by docker compose.

# Project name (matches docker-compose.yml `name:` — containers/images use recruiting-ai-*)
COMPOSE_PROJECT_NAME=recruiting-ai

# Rails / JWT (min ~32 chars; change for anything beyond local dev)
SECRET_KEY_BASE=development_secret_key_base_change_me_min_32_characters_long

# PostgreSQL (must match backend DATABASE_* usage)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=recruiting_ai_development

# Optional: if 5432, 3000, or 5173 are taken on the host
# POSTGRES_PORT=5433
# BACKEND_PORT=3001
# FRONTEND_PORT=5174

# CORS (comma-separated origins for direct browser → API calls, e.g. without Vite proxy)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend API base (Docker default uses Vite /api proxy to backend:3000)
VITE_API_URL=http://localhost:5173/api
